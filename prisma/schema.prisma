generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  STORE
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model StoreUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         UserRole  @default(STORE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Store {
  id             String   @id @default(cuid())
  name           String   @default("我的美甲店")
  logo           String?  @db.Text
  depositEnabled Boolean  @default(false)
  depositAmount  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  businessHours  BusinessHour[]
  businessSlots  BusinessSlot[]
  exceptionDates ExceptionDate[]
  bankAccounts   BankAccount[]
}

model BusinessHour {
  id        String  @id @default(cuid())
  storeId   String
  dayOfWeek Int
  isOpen    Boolean @default(true)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, dayOfWeek])
}

model BusinessSlot {
  id        String @id @default(cuid())
  storeId   String
  dayOfWeek Int
  time      String // "10:00"

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, dayOfWeek, time])
}

model ExceptionDate {
  id       String   @id @default(cuid())
  storeId  String
  date     DateTime @db.Date
  isClosed Boolean  @default(true)
  note     String?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, date])
}

model BankAccount {
  id            String @id @default(cuid())
  storeId       String
  bankName      String
  accountNumber String
  accountName   String
  order         Int    @default(0)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model ServiceCategory {
  id       String    @id @default(cuid())
  name     String
  storeId  String
  order    Int       @default(0)
  services Service[]

  @@unique([storeId, name])
}

model Service {
  id          String  @id @default(cuid())
  name        String
  price       Int
  duration    Int
  description String?
  isActive    Boolean @default(true)
  storeId     String
  categoryId  String?
  order       Int     @default(0)

  category            ServiceCategory?     @relation(fields: [categoryId], references: [id])
  appointmentServices AppointmentService[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  notes     String?
  storeId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]

  @@unique([storeId, phone])
}

model Appointment {
  id            String            @id @default(cuid())
  customerId    String
  storeId       String
  date          DateTime          @db.Date
  startTime     String
  endTime       String
  status        AppointmentStatus @default(PENDING)
  totalPrice    Int
  totalDuration Int
  notes         String?
  transferCode  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  customer Customer             @relation(fields: [customerId], references: [id])
  services AppointmentService[]
}

model AppointmentService {
  id            String @id @default(cuid())
  appointmentId String
  serviceId     String
  serviceName   String
  price         Int
  duration      Int

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id])
}
